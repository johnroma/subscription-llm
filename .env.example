# Server configuration
HOST=127.0.0.1
PORT=8789

# Authentication (required if HOST is not 127.0.0.1 or ::1)
# SUBSCRIPTION_LLM_TOKEN=your-secure-token-here

# Codex CLI configuration
CODEX_BIN=codex

# Model configuration (token-optimized defaults)
DEFAULT_MODEL=gpt-4.1-mini
ALLOWED_MODELS=gpt-4.1-mini,gpt-4o-mini,gemini-2.5-flash-exp

# Request limits
MAX_CONCURRENT_REQUESTS=8
REQUEST_TIMEOUT_MS=120000

# Input limits
MAX_PROMPT_LENGTH=64000
MAX_IMAGE_SIZE=10000000
MAX_IMAGES_PER_REQUEST=5
